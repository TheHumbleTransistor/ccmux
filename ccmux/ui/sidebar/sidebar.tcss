Screen {
    background: #1e1e1e;
    layout: vertical;
}

#title {
    height: 1;
    padding: 0 1;
    color: #d7af5f;
    background: #1e1e1e;
    text-style: bold;
}

#header {
    height: 1;
    padding: 0 1;
    background: #1e1e1e;
    color: #bcbcbc;
}

#spacer {
    height: 1;
    background: #1e1e1e;
}

#instance-list {
    background: #1e1e1e;
    height: 1fr;
}
